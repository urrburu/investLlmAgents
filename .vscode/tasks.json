{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "FastAPI: Run with uv",
      "type": "shell",
      "command": "uv",
      "args": [
        "run",
        "uvicorn",
        "main:app",
        "--reload",
        "--host",
        "127.0.0.1",
        "--port",
        "8000"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
